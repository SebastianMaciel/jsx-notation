{
  "name": "jsx-notation",
  "version": "0.1.5",
  "mcpName": "io.github.SebastianMaciel/jsx-notation",
  "description": "JSXN encoder/decoder — compact notation for React/Next.js files, optimized for LLMs",
  "author": "Sebastián Maciel",
  "type": "module",
  "exports": "./src/index.js",
  "main": "./src/index.js",
  "bin": {
    "jsx-notation-mcp": "mcp/index.js"
  },
  "files": [
    "src/**/*.js",
    "mcp/index.js"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  },
  "keywords": [
    "jsx",
    "tsx",
    "react",
    "nextjs",
    "notation",
    "compact",
    "encoder",
    "decoder",
    "llm",
    "token-optimization",
    "mcp",
    "ai",
    "claude",
    "html",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianMaciel/jsx-notation.git"
  },
  "homepage": "https://sebastianmaciel.github.io/jsx-notation/",
  "bugs": {
    "url": "https://github.com/SebastianMaciel/jsx-notation/issues"
  },
  "license": "MIT"
}
